NEXT_PUBLIC_SITE_URL=http://localhost:4000
BACKEND_API_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:4000

# Supabase Settings (Get from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron Secret (Generate a random string for protecting cron route)
CRON_SECRET=your-random-secret

# Google Search Console (For Rank Tracking)
GSC_CLIENT_EMAIL=your-service-account-email
GSC_PRIVATE_KEY="your-private-key-with-\n-newlines"
GSC_SITE_URL=https://your-domain.com
